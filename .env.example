# ════════════════════════════════════════════════════════════════════
# .env.example — SIMS Webmapping
# ════════════════════════════════════════════════════════════════════
# Copier ce fichier en .env et remplir les valeurs avant de démarrer.
# NE JAMAIS committer le fichier .env réel dans git.
# ════════════════════════════════════════════════════════════════════

# ── PostgreSQL / PostGIS ─────────────────────────────────────────
POSTGRES_DB=sims_db
POSTGRES_USER=sims_user
POSTGRES_PASSWORD=sims_password_changeme

# ── GeoServer ────────────────────────────────────────────────────
GEOSERVER_URL=http://localhost:8080/geoserver
GEOSERVER_USER=admin
GEOSERVER_PASSWORD=geoserver_changeme

# ── Django ───────────────────────────────────────────────────────
# Générer avec : python -c "import secrets; print(secrets.token_hex(50))"
DJANGO_SECRET_KEY=django-insecure-changeme-generate-with-python-c-import-secrets-secrets-token-hex-50
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ── CORS (origines autorisées par Django) ────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# ── URLs internes ────────────────────────────────────────────────
# En Docker, ces valeurs sont injectées directement via docker-compose.yml
# (noms de service : db, geoserver). Ces variables servent uniquement
# au développement local hors Docker.
DATABASE_URL=postgis://sims_user:sims_password_changeme@localhost:5432/sims_db

# ── JWT ──────────────────────────────────────────────────────────
# ACCESS_TOKEN_LIFETIME_MINUTES=60
# REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Cache Redis (optionnel — remplace LocMemCache en production) ──
# REDIS_URL=redis://localhost:6379/0

# ── Médias (fichiers uploadés) ────────────────────────────────────
# MEDIA_ROOT=/var/www/sims/media
# MEDIA_URL=/media/

# ── Email (notifications, reset password) ────────────────────────
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=noreply@example.com
# EMAIL_HOST_PASSWORD=your-smtp-password
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=SIMS Platform <noreply@example.com>

# ── Sentry (monitoring erreurs — optionnel) ───────────────────────
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
